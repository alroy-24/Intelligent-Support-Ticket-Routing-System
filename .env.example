# Copy to .env and fill in.
# .env is gitignored; never commit secrets.

# LLM provider keys (used for synthetic labeling + summarization).
# Set ONE of these — the labeler auto-picks based on which is present.
# Groq is preferred when both are set (free tier, fast).

GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local cache for LLM responses (sha256-keyed)
LLM_CACHE_DIR=.cache/llm

# API service
TICKETROUTING_HOST=0.0.0.0
TICKETROUTING_PORT=8000

# Redis (optional, for production response caching)
REDIS_URL=redis://localhost:6379/0
